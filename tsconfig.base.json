{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@paddie-studio/types": ["packages/types/src"],
      "@paddie-studio/ui": ["packages/ui/src"],
      "@paddie-studio/runtime": ["packages/runtime/src"],
      "@paddie-studio/connectors-core": ["packages/connectors-core/src"],
      "@paddie-studio/connectors-paddie": ["packages/connectors-paddie/src"]
    }
  }
}
